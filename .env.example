# Discord Bot Settings
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_INSTRUCTIONS=your-channel-id-to-monitor
DISCORD_INSTRUCTION_USER_ID=your-discord-user-id

# Copilot Bridge Settings
COPILOT_PROJECT_ROOT=/path/to/your/project
DISCORD_COPILOT_MODEL=gpt-5.4
DISCORD_COPILOT_SESSION_ID=
# COPILOT_BIN_DIR=/path/to/bin

# (Optional) Custom file paths for multi-bridge setups
# BRIDGE_STATE_FILE=~/.copilot/discord_to_copilot_bridge_state.json
# BRIDGE_LOCK_FILE=~/.copilot/discord_to_copilot_bridge.lock
# BRIDGE_HEARTBEAT_FILE=~/.copilot/discord_to_copilot_bridge.heartbeat.json

# (Optional) Custom prompt prefix sent to Copilot for each Discord message
# BRIDGE_PROMPT_PREFIX=New instructions from Discord. Work in /path/to/project.
